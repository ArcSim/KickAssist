# CurseForge / BigWigs packager metadata.
# Everything under `ignore` is left OUT of the packaged addon.
package-as: KickAssist

# Use our formatted changelog for the CurseForge / Wago file notes instead of
# the packager's auto-generated commit-message list.
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .git
  - .github
  - .gitignore
  - .gitattributes
  - .claude
  - CLAUDE.md
  - .pkgmeta
  - README.md
  - "*.bak"
